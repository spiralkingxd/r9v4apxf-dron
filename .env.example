# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados

# URL do seu projeto Supabase (encontrado em Project Settings > API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública do Supabase (encontrada em Project Settings > API)
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-publica

# (Opcional) ID do usuário admin para funcionalidades de teste local
# Em produção, isso é gerenciado via banco de dados (tabela profiles)
VITE_ADMIN_DISCORD_ID=262059919182659587
