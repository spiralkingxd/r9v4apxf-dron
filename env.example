# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform owner
# Use your real Discord numeric ID (Snowflake, 15-22 digits).
# How to get it:
# 1) Discord -> User Settings -> Advanced -> enable Developer Mode.
# 2) Right click your username/avatar -> Copy User ID.
# 3) Paste that number below.
OWNER_DISCORD_ID=

# Optional additional admins (comma-separated Discord IDs)
# Example: ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
ADMIN_DISCORD_IDS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Optional Discord bot integration (future)
DISCORD_BOT_USER_ID=your-discord-bot-user-id
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_BOT_TOKEN=your-discord-bot-token

# Optional Xbox integration
XBOX_TITLE_ID=your-xbox-title-id

# Ranking defaults
MATCH_POINTS_WIN=3
MATCH_POINTS_DRAW=1
MATCH_POINTS_LOSS=0

# Vercel optional
VERCEL_PROJECT_PRODUCTION_URL=madnessarena.vercel.app
